MainScreenManager:
    LanguageScreen:
    StartScreen:
    MusicSingleDownloadScreen:
    MusicPlaylistDownloadScreen:
    OptionsAndInfosScreen:

<BackButton@AnchorLayout>:
    size_hint: (None, None)
    size: (120,120)
    pos_hint: {'x': 0.04, 'top': 0.96}
    BasicButton:
        id: anchor_back_btn_no_trad
        canvas.before:
            Color:
                rgba: app.color(255,255,255,255)
            RoundedRectangle:
                size : self.size
                pos: self.pos
                radius: [16]
        on_press:
            root.parent.parent.back_btn()
    Image:
        source: "assets/left-arrow.png"
        allow_strech: False
        keep_ratoo: False
        background_color: (0.5,0.5,0.5,1)

<BasicButton@Button>:
    font_size: app.text_size("medium")
    color: app.color(20, 15, 15, 175)
    font_name: app.Roboto_font
    background_color: (0 ,0 ,0 , 0)
    canvas.before:
        Color:
            rgba: app.color(240,238,238,255)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [self.height/2]
<ButtonForList@Button>:
    font_size: app.text_size("medium")
    color: app.color(20, 15, 15, 175)
    font_name: app.Roboto_font
    background_color: (0 ,0 ,0 , 0)
    size_hint_y: None
    height: 135
    canvas.before:
        Color:
            rgba: app.color(240,238,238,255)
        Rectangle:
            size: self.size
            pos: self.pos


<ProgressBar>:
    max: 100
    opacity: 1



<LanguageScreen>:
    AnchorLayout:
        size: root.width, root.height
        anchor_x: 'center'
        anchor_y: 'center'
        GridLayout:
            cols: 1
            rows: 2
            size_hint: (None, None)
            spacing: 12
            size: (300, 450)
            BasicButton:
                text: 'Français'
                on_press:
                    root.setLanguage('fr')
                    
                size_hint_y: 0.5
            BasicButton:
                text: 'English'
                on_press:
                    root.setLanguage('en')
                    
                size_hint_y: 0.5

<StartScreen>:
    BoxLayout:
        orientation: 'vertical'
        size: root.width, root.height
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "bottom"
            size_hint_y: .6
            Label:
                id: SS_label
                text : "Welcome to [color=#FF0000][font=Roboto-Bold]Hyp'Load[/font][/color], your personnal\nYoutube video downloader."
                line_height: 1.3
                halign: "center"
                markup: True
                color: app.color(20, 15, 15, 175)
                font_size: app.text_size("medium big")
                font_name: app.Roboto_font
                size_hint_y: None
                height: 400
        AnchorLayout:
            anchor_x: "center"
            anchor_y:"top"
            GridLayout:
                id: SS_grid_for_btn_no_trad
                cols: 1
                rows: 4
                spacing: 35
                height: 700
                size_hint_y: None
                size_hint_x: None
                width: 750
                BasicButton:
                    id: SS_single_btn
                    text: "Download a single video"
                    
                    on_press:
                        root.manager.current = 'music_single_download_screen'
                BasicButton:
                    id: SS_playlist_btn
                    text: "Download a playlist"
                    
                    
                    
                    on_press:
                        root.manager.current = "music_playlist_download_screen"
                BasicButton:
                    id: SS_my_playlists_btn
                    text: "My playlists saved"
                    
                    
                    on_press:
                        root.manager.current = "start_screen"
                BasicButton:
                    id: SS_others_btn
                    text: "Options and infos"
                    
                    on_press:
                        root.manager.current="options_and_infos_screen"
                    



<MusicSingleDownloadScreen>:
    FloatLayout:
        size: root.width, root.height
        BackButton:

        GridLayout:
            pos_hint: {"center_x": 0.5, 'center_y': 0.52}
            id: container_download_screen_no_trad
            cols: 1
            rows: 2
            size_hint: (None, None)
            size: (800, 200)
            spacing: 30
            Label:
                id: MSDS_label
                text: 'Enter the link of your YouTube playlist'
                halign: "center"
                color: app.color(20, 15, 15, 175)
                font_size: app.text_size("small medium")
                font_name: app.Roboto_font
            GridLayout:
                id: enter_link_grid_no_trad
                cols: 2
                rows: 1
                TextInput:
                    font_name: app.Roboto_font
                    hint_text: "Your YouTube video's link"
                    id: input_of_youtube_link
                    multiline: False
                    background_normal: ''
                    background_color: (0.95,0.95,0.95,1)
                    foreground_color: (0.8,0,0,1)
                    font_size: 40
                    padding: [0,19,0,0]
                    on_text_validate: root.download()
                    background_active: ''
                    canvas.after:
                        Color:
                            rgba: (0.95,0.95,0.95,1)
                        Ellipse:
                            angle_start: 180
                            angle_end: 360
                            pos: (self.pos[0] - (self.height/2.4), self.pos[1])
                            size: (self.height/1.2,self.height)
                        Rectangle:
                            size: self.width, 5
                            pos: self.pos[0], self.height
                BasicButton:
                    id: MSDS_validate_link_btn
                    text: 'Download'
                    font_size: app.text_size("small medium")
                    on_press: root.download()
                    color: (1,1,1,1)
                    size_hint_x: None
                    width: app.auto_width(self) + 30
                    text_size: self.size
                    halign:"right"
                    valign:"center"
                    canvas.before:
                        Color:
                            rgba: app.color(252, 68, 68, 255)
                        Rectangle:
                            size : self.size
                            pos: self.pos
                    canvas.after:
                        Color:
                            rgba: app.color(252, 68, 68, 255)
                        Ellipse:
                            angle_start: 0
                            angle_end: 180
                            pos: (self.pos[0] +self.width - (self.height/2.4), self.pos[1])
                            size: (self.height/1.2,self.height)


<MusicPlaylistDownloadScreen>:
    FloatLayout:
        size: root.width, root.height
        BackButton:
        GridLayout:
            pos_hint: {"center_x": 0.5, 'center_y': 0.5}
            id: container_playlist_download_screen_no_trad
            cols: 1
            rows: 2
            size_hint: (None, None)
            size: (750, 200)
            spacing: 30
            Label:
                id: MPDS_label
                text: 'Enter the link of your YouTube playlist'
                color: app.color(20, 15, 15, 175)
                font_size: app.text_size("small medium")
                font_name: app.Roboto_font
            GridLayout:
                id: enter_playlist_link_grid_no_trad
                cols: 2
                rows: 1
                TextInput:
                    font_name: app.Roboto_font
                    hint_text: "Your YouTube playlist's link"
                    id: input_of_youtube_playlist_link
                    multiline: False
                    background_normal: ''
                    background_active: ''
                    background_color: (0.95,0.95,0.95,1)
                    foreground_color: (0.8,0,0,1)
                    font_size: 40
                    padding: [0,19,0,0]
                    on_text_validate: root.download()
                    outline_color: 0,0,0,0
                    canvas.after:
                        Color:
                            rgba: (0.95,0.95,0.95,1)
                        Ellipse:
                            angle_start: 180
                            angle_end: 360
                            pos: (self.pos[0] - (self.height/2.4), self.pos[1])
                            size: (self.height/1.2,self.height)
                BasicButton:
                    id: MPDS_validate_link_btn
                    text: 'Validate'
                    on_press: root.download()
                    color: (1,1,1,1)
                    font_size: app.text_size("small medium")
                    size_hint_x: None
                    width: 200
                    text_size: self.size
                    halign:"right"
                    valign:"center"
                    canvas.before:
                        Color:
                            rgba: app.color(252, 68, 68, 255)
                        Rectangle:
                            size : self.size
                            pos: self.pos
                    canvas.after:
                        Color:
                            rgba: app.color(252, 68, 68, 255)
                        Ellipse:
                            angle_start: 0
                            angle_end: 180
                            pos: (self.pos[0] +self.width - (self.height/2.4), self.pos[1])
                            size: (self.height/1.2,self.height)

                            
                                                        
                                                            
<OptionsAndInfosScreen>:
    FloatLayout:
        size: root.width, root.height
        
        GridLayout:
            id: OAIS_grid_container_no_trad
            spacing: 35
            orientation:"tb-lr"
            height: len(self.children) * (OAIS_change_lang_btn.height + self.spacing[0]) - self.spacing[0]
            size_hint:(None,None)
            width: 700
            cols:1
            pos_hint:{"center_x":0.5,"center_y":0.505}
            BasicButton:
                id: OAIS_how_btn
                text:"How to use Hyp'Load ?"
            BasicButton:
                id: OAIS_change_res_btn
                text:"Resolution of the videos"
            BasicButton:
                id: OAIS_who_am_i
                text: "Who is Hypocrate ?"
                on_press:
                    app.test()
            BasicButton:
                size_hint_y: None
                height: 148.75
                id: OAIS_change_lang_btn
                text:"Change the language"
                on_press:
                    root.manager.transition.direction = "left"
                    root.manager.current="language_screen"
            BasicButton:
                text:"test"
        BackButton:
            
            